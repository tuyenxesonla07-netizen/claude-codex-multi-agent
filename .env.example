# LLM API Configuration
# Copy this file to .env and fill in your values

# Option A: dayueai.fun (default)
LLM_API_BASE_URL=https://www.dayueai.fun
LLM_API_KEY=your-api-key-here
LLM_API_MODEL=claude-opus-4-7

# Option B: OpenAI-compatible (requires: pip install httpx)
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-key
# LLM_API_MODEL=gpt-4o

# Option C: Anthropic direct (requires: pip install anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
