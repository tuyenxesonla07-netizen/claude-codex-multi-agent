# KodeForge compliance-focused environment template
# Copy to .env and fill in before running docker compose or docker run.
# Only ANTHROPIC_API_KEY and OPENAI_API_KEY are optional; everything else
# has a sensible default for first-time evaluation.

# ── LLM Provider (at least one required for code generation & review) ───
# Pick ONE provider:

# Option A: Anthropic Claude (recommended for code review quality)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=

# Option B: OpenAI-compatible (DeepSeek, Tongyi, Zhipu, Kimi, MiniMax)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Option C: Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── API Server (only needed for `serve` command) ────────────────────────
CC_SERVER_HOST=0.0.0.0
CC_SERVER_PORT=8080
CC_API_KEYS=                                     # comma-separated; empty = no auth (dev only)
CC_CORS_ORIGINS=*
CC_PROTECT_DOCS=false
CC_RATE_LIMIT=
CC_MAX_CONCURRENT=5
CC_TIMEOUT=300

# ── Quality Gate preset ──────────────────────────────────────────────────
# Choose one: financial-general | financial-tier3 | financial-sox | hipaa-phi
KODEFORGE_PRESET=financial-general
HITL_THRESHOLD=clinical                          # clinical blocks on critical+high; standard blocks only on critical

# ── Audit log ─────────────────────────────────────────────────────────────
AUDIT_LOG_DIR=/tmp/audit
AUDIT_RETENTION_DAYS=2190                        # 6 years (SOC 2 requirement)
AUDIT_IMMUTABLE=true

# ── Observability ─────────────────────────────────────────────────────────
CC_LOG_LEVEL=INFO
OTEL_EXPORTER_ENDPOINT=                          # optional: OpenTelemetry collector
