{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data Processing & Transformation Output",
  "description": "Output schema for Data Processing & Transformation module expert agent",
  "type": "object",
  "required": [
    "module_spec",
    "confidence",
    "reasoning"
  ],
  "properties": {
    "module_spec": {
      "type": "object",
      "required": [
        "components",
        "interfaces",
        "acceptance_criteria"
      ],
      "properties": {
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "type",
              "description"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "enum": [
                  "service",
                  "model",
                  "middleware",
                  "route",
                  "util"
                ]
              },
              "description": {
                "type": "string"
              },
              "methods": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "interfaces": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "method",
              "path"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "method": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "input_schema": {
                "type": "object"
              },
              "output_schema": {
                "type": "object"
              }
            }
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "state_machine": {
          "type": "object",
          "description": "State machine definition for data processing pipeline",
          "properties": {
            "initial_state": {"type": "string"},
            "states": {
              "type": "array",
              "items": {"type": "string"}
            },
            "transitions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "from": {"type": "string"},
                  "to": {"type": "string"},
                  "trigger": {"type": "string"}
                }
              }
            }
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reasoning": {
      "type": "string"
    }
  }
}