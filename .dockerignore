# .dockerignore — Exclude sensitive and unnecessary files from Docker build context

# Version control
.git

# Environment files (secrets!)
.env
.env.*
*.env

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
.venv
venv/
ENV/
.pytest_cache
.tox

# IDE
.idea
.vscode
*.swp
*.swo

# Data directories (runtime state)
data/
.checkpoints/
.sessions/
*.db
*.sqlite
*.sqlite3

# Docs (not needed in image)
docs/
*.md
LICENSE

# Docker (avoid recursive copy)
Dockerfile*
docker-compose*
.dockerignore

# CI
.github

# Temp files
tmp/
temp/
*.tmp
*.log

# Misc
.DS_Store
*.egg-info
